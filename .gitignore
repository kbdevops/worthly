# SQLite database (all data stored here) — *.db catches prices.db and demo/fake.db;
# WAL mode also creates -wal/-shm sidecar files that need excluding too
*.db
*.db-wal
*.db-shm
*.db-journal

# Raw import files
*.xlsx
*.csv

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Frontend build artifacts
frontend/dist/
frontend/node_modules/

# macOS
.DS_Store

# IDE
.vscode/
.idea/

# Backup files
*_backup.*
